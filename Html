                const qNum = index + 1;
                imgTag.style.display = 'block';
                imgTag.src = `問題${qNum}.png`;
                
                imgTag.onerror = function() {
                    this.onerror = function() {
                        this.onerror = function() { 
                            this.style.display = 'none';
                        };
                        this.src = `問題${qNum}.jpg`;
